{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "lib": ["DOM", "DOM.Iterable", "esnext", "esnext.array", "esnext.asynciterable", "esnext.symbol"],
        "module": "preserve",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": false,
        "target": "ESNEXT",
        "jsx": "preserve",

        // @vencord/types has some errors for now
        "skipLibCheck": true,

        "paths": {
            "*": ["./src/*"],
        },

        "types": ["node", "@vencord/types"]
    },
    "include": ["src/**/*"]
}
